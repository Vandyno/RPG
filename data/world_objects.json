    "global_tile": [4, 5],
    "interaction_radius": 128,
    "prefer_primary_action": false,
    "description": "The job board is mounted inside Briarwatch's town hall, close enough to the square for travelers to find it but sheltered where official notices, patrol work, and town records belong.",
