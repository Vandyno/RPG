          {
            "type": "start_quest",
            "quest_id": "quest_briarwatch_road_patrol"
          }
        ],
        "response": "The posting marks the road thug west of Briarwatch. Clear the road, then report back here."
      },
      {
        "id": "review_road_patrol",
        "text": "Review Road Patrol Job",
        "conditions": [
          {
            "type": "quest_state",
            "quest_id": "quest_briarwatch_road_patrol",
            "state": "active"
          },
          {
            "type": "not_flag",
            "flag_id": "flag_spawn_enemy_defeated"
          }
        ],
        "response": "The posting still points west: drive off the road thug before another cart gets stopped."
      },
      {
        "id": "report_road_patrol",
        "text": "Report Road Patrol Complete",
        "conditions": [
          {
            "type": "quest_state",
            "quest_id": "quest_briarwatch_road_patrol",
            "state": "active"
          },
          {
            "type": "has_flag",
            "flag_id": "flag_spawn_enemy_defeated"
          }
        ],
        "effects": [
          {
            "type": "complete_quest",
            "quest_id": "quest_briarwatch_road_patrol"
          }
        ],
        "response": "The board clerk marks the road clear and leaves your pay in the lockbox."
      }
    ]
  },
