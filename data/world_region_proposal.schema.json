{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://data/world_region_proposal.schema.json",
  "title": "Editable Atlas-Constrained Region Proposal",
  "type": "object",
  "required": ["schema_version", "proposal_status", "activation_status", "id", "atlas_id", "atlas_region_id", "seed", "template", "generator_version", "atlas_approval", "terrain_palette", "terrain_cells", "fixed_constraints", "minor_routes", "pois", "review"],
  "properties": {
    "proposal_status": {"const": "proposal"},
    "activation_status": {"const": "review_required"},
    "seed": {"type": "integer"},
    "terrain_palette": {"type": "object", "minProperties": 1},
    "terrain_cells": {"type": "array", "minItems": 1},
    "fixed_constraints": {"type": "object"},
    "minor_routes": {"type": "array"},
    "pois": {"type": "array"}
  }
}
