{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://data/world_settlement_proposal.schema.json",
  "title": "Editable Atlas-Constrained Settlement Proposal",
  "type": "object",
  "required": ["schema_version", "proposal_status", "activation_status", "id", "atlas_id", "atlas_region_id", "atlas_settlement_id", "seed", "template", "generator_version", "atlas_approval", "anchor_global_tile", "bounds", "districts", "streets", "defenses", "plots", "structure_archetypes", "structures", "portals", "npc_role_slots", "service_slots", "interior_fixture_slots", "quest_hook_slots", "encounter_zones", "review"],
  "properties": {
    "proposal_status": {"const": "proposal"},
    "activation_status": {"const": "review_required"},
    "seed": {"type": "integer"},
    "districts": {"type": "array", "minItems": 1},
    "streets": {"type": "array", "minItems": 1},
    "plots": {"type": "array", "minItems": 1},
    "structure_archetypes": {"type": "object", "minProperties": 1},
    "structures": {"type": "array", "minItems": 2},
    "portals": {"type": "array", "minItems": 2},
    "npc_role_slots": {"type": "array", "minItems": 1},
    "service_slots": {"type": "array", "minItems": 1},
    "interior_fixture_slots": {"type": "array", "minItems": 1},
    "quest_hook_slots": {"type": "array", "minItems": 1}
  }
}
